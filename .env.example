# .env.example — Copy this file to .env and fill in your real values.
# .env is gitignored and never committed.

# Path to your downloaded Google Service Account JSON key
GOOGLE_CREDENTIALS_PATH=credentials.json

# Google Spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive folder IDs (from the URL: drive.google.com/drive/folders/FOLDER_ID)
DRIVE_FOLDER_RECEIPTS=your_receipts_folder_id_here
DRIVE_FOLDER_MAINTENANCE=your_maintenance_folder_id_here
DRIVE_FOLDER_DOCUMENTS=your_documents_folder_id_here
# Parent folder for property photos — app auto-creates per-property subfolders inside it
DRIVE_FOLDER_PHOTOS=your_photos_folder_id_here

# Optional: set a password to protect the app (leave blank for open access)
APP_PASSWORD=

# Veryfi receipt OCR credentials (~$0.08/receipt, pay-per-use)
# Sign up at veryfi.com — free credits to start
# Leave blank to disable OCR (you'll fill in expense forms manually)
VERYFI_CLIENT_ID=
VERYFI_CLIENT_SECRET=
VERYFI_API_KEY=
